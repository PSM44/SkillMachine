# =========================
# SkillMachine — EOL policy
# =========================
# Goal: deterministic line endings across environments.

# Default: normalize text to LF (git internal)
* text=auto

# Windows-first
*.ps1 text eol=crlf
*.txt text eol=crlf

# Cross-platform standards
*.md  text eol=lf
*.json text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.xml text eol=lf
*.csv text eol=lf

# Shell scripts
*.sh text eol=lf

# Binary
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.pdf binary
*.zip binary
*.7z binary
*.exe binary
*.dll binary
